{
  "name": "@tuicons/core",
  "version": "0.1.0",
  "description": "Framework-agnostic terminal icon resolver",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/rexroze/tuicons/tree/main/packages/core#readme",
  "bugs": { "url": "https://github.com/rexroze/tuicons/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rexroze/tuicons.git",
    "directory": "packages/core"
  },
  "keywords": ["tui", "terminal", "icons", "nerd-fonts", "unicode"],
  "engines": { "node": ">=20" },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" }
  },
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.tsbuildinfo", "README.md", "LICENSE"],
  "publishConfig": { "access": "public", "provenance": true },
  "dependencies": { "@tuicons/nerd-fonts": "workspace:*" },
  "scripts": { "build": "tsc -b", "test": "vitest run" }
}
