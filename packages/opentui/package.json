{
  "name": "@tuicons/opentui",
  "version": "0.1.0",
  "description": "OpenTUI adapter for TUIcons",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/rexroze/tuicons/tree/main/packages/opentui#readme",
  "bugs": { "url": "https://github.com/rexroze/tuicons/issues" },
  "repository": {
    "type": "git",
